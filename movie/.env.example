# Copy to .env and fill in your proxy details:
#   cp .env.example .env
#
# Full guide: config/PROXY-SETUP.md

# One proxy for all agents (optional if using proxy-docket.json instead)
# Replace with your provider URL — do not commit real credentials
MOVIE_FINDER_PROXY=

# Example formats (uncomment and edit one line after signing up with a provider):
# MOVIE_FINDER_PROXY=http://username:password@gate.provider.com:8080
# MOVIE_FINDER_PROXY=socks5://username:password@gate.provider.com:1080

# Standard proxy env vars (lower priority than MOVIE_FINDER_PROXY in the app)
HTTP_PROXY=
HTTPS_PROXY=

# Optional tuning
MOVIE_WORKERS=16
MOVIE_TIMEOUT=45s

# Self-hosted edgeproxy (VPS) — see config/SELF-HOST-PROXY.md
# PROXY_USER=
# PROXY_PASS=
# PROXY_PORT=8888
