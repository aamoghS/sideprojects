# Copy to plate.env and edit. run.sh loads this automatically.
# cp plate.env.example plate.env

PLATE_PROVIDER=docker
PLATE_LISTEN=:8080
PLATE_DATA=.plate
PLATE_API=http://127.0.0.1:8080
PLATE_DOCKER_IMAGE=ubuntu:22.04

# Proxmox (when PLATE_PROVIDER=proxmox)
# PLATE_PROXMOX_URL=https://your-host:8006
# PLATE_PROXMOX_USER=root@pam
# PLATE_PROXMOX_PASSWORD=
# PLATE_PROXMOX_NODE=pve
# PLATE_PROXMOX_TEMPLATE=9000
# PLATE_PROXMOX_STORAGE=local-lvm
# PLATE_PROXMOX_BRIDGE=vmbr0
# PLATE_PROXMOX_INSECURE=true
